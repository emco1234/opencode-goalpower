{
  "name": "goalpower",
  "version": "1.2.0",
  "description": "Long-running autonomous goal mode with multi-round skeptic verification for OpenCode. Stop accepting 'I'm done' on faith — make every completion claim pass a panel of adversarial skeptics.",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "goal",
    "goal-mode",
    "skeptic",
    "autonomous",
    "long-running",
    "ai-agent",
    "verifiable",
    "anti-fabrication"
  ],
  "license": "MIT",
  "author": "emco1234",
  "homepage": "https://github.com/emco1234/goalpower",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emco1234/goalpower.git"
  },
  "bugs": {
    "url": "https://github.com/emco1234/goalpower/issues"
  },
  "type": "module",
  "exports": {
    "./server": {
      "import": "./src/server.ts"
    },
    "./tui": {
      "import": "./src/tui.tsx"
    }
  },
  "files": [
    "src",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "opencode": {
    "type": "plugin",
    "server": "./src/server.ts",
    "tui": "./src/tui.tsx"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  },
  "engines": {
    "opencode": ">=1.17.1"
  }
}
